# Ollama Cloud API Configuration
# Get your API key from https://ollama.com/

# Your API Key (replace with your actual key)
OLLAMA_CLOUD_API_KEY=your_api_key_here

# API URL
OLLAMA_CLOUD_API_URL=https://ollama.com/api/chat

# Chat Model (choose from your available models)
OLLAMA_CLOUD_MODEL=gpt-oss:20b-cloud

# Available Models:
# - gpt-oss:120b-cloud
# - gpt-oss:20b-cloud
# - deepseek-v3.1:671b-cloud
# - qwen3-coder:480b-cloud
# - qwen3.5:397b-cloud
# - minimax-m2.5:cloud
# - kimi-k2.5:cloud
